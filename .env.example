# Enhanced Agent Bus runtime examples
# Copy only the values you actually need for your deployment shape.

# ---------------------------------------------------------------------------
# Tenant-route / shared bus JWT validation
# ---------------------------------------------------------------------------
# Used by packages/enhanced_agent_bus/routes/tenants.py
JWT_SECRET_KEY=replace-with-32+-char-secret
JWT_ALGORITHM=HS256
JWT_ISSUER=acgs2-agent-runtime
JWT_AUDIENCE=acgs2-services

# Optional admin-key auth for tenant routes
TENANT_ADMIN_KEY=

# ---------------------------------------------------------------------------
# Collaboration API JWT validation
# ---------------------------------------------------------------------------
# CollaborationAPI is intentionally HS256-only because it validates with a
# shared secret (COLLABORATION_SECRET_KEY) rather than asymmetric keys.
COLLABORATION_SECRET_KEY=replace-with-collaboration-secret
COLLABORATION_JWT_ALGORITHM=HS256

# ---------------------------------------------------------------------------
# Session governance SDK tokens
# ---------------------------------------------------------------------------
# Session tokens are configured independently from tenant/collaboration JWTs.
SESSION_JWT_ALGORITHM=RS256
SESSION_JWT_ISSUER=acgs2-session-governance
SESSION_JWT_AUDIENCE=acgs2-services

# ---------------------------------------------------------------------------
# Core service secret used by related governance features
# ---------------------------------------------------------------------------
ACGS2_SERVICE_SECRET=replace-with-service-secret
